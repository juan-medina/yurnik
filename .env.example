# Copy to .env and fill in secrets. Never commit .env.
# Run `make gen-keys` once to generate keys/dpop.pem and keys/session.pem before starting the API.

# --- Database (generated by scripts/db-init.ps1) ---
DATABASE_URL=postgres://agon_api:<password>@localhost:5432/agon_dev
DATABASE_ADMIN_URL=postgres://agon_admin:<password>@localhost:5432/agon_dev

# --- IGDB (Twitch developer console — https://dev.twitch.tv/console) ---
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- AT Proto ---
ATPROTO_PDS_URL=https://bsky.social

# --- API server ---
SERVER_ADDR=:8080
DPOP_KEY_FILE=../keys/dpop.pem
SESSION_KEY_FILE=../keys/session.pem

# Use 127.0.0.1 throughout so cookies survive the OAuth redirect (localhost != 127.0.0.1)
FRONTEND_URL=http://127.0.0.1:5173
ALLOWED_ORIGIN=http://127.0.0.1:5173

# Frontend (Vite)
VITE_API_URL=http://127.0.0.1:8080

# Bluesky OAuth (loopback dev setup — no changes needed for local use)
BLUESKY_CLIENT_ID=http://localhost
BLUESKY_REDIRECT_URI=http://127.0.0.1:8080/auth/callback
BLUESKY_AUTH_ENDPOINT=https://bsky.social/oauth/authorize
BLUESKY_PAR_ENDPOINT=https://bsky.social/oauth/par
BLUESKY_TOKEN_ENDPOINT=https://bsky.social/oauth/token
