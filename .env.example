# Copy to .env and fill in secrets. Never commit .env.
# Run `make gen-keys` once to generate keys/session.pem before starting the API.

# --- Database (generated by make db-init) ---
DATABASE_URL=postgres://yurnik_api:<password>@localhost:5432/yurnik
DATABASE_ADMIN_URL=postgres://yurnik_admin:<password>@localhost:5432/yurnik

# --- IGDB (Twitch developer console — https://dev.twitch.tv/console) ---
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- API server ---
SERVER_ADDR=:8080
SESSION_KEY_FILE=../keys/session.pem
FRONTEND_URL=http://127.0.0.1:5173
ALLOWED_ORIGIN=http://127.0.0.1:5173

# Global request rate cap across all clients. Protects against traffic spikes and retry storms.
RATE_LIMIT_RPS=100

# Frontend (Vite)
VITE_API_URL=http://127.0.0.1:8080

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8080/auth/callback
DISCORD_AUTH_ENDPOINT=https://discord.com/oauth2/authorize
DISCORD_TOKEN_ENDPOINT=https://discord.com/api/oauth2/token
DISCORD_USER_ENDPOINT=https://discord.com/api/users/@me


# --- Cloudflare R2 (Cloudflare dashboard → R2 → Manage API tokens) ---
# Account ID: R2 overview page (right sidebar)
# Access Key ID + Secret Access Key: generated when creating an API token
# Bucket name: the R2 bucket used for user avatar uploads
# Public URL: the public bucket URL (set under bucket Settings → Public access)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
